<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/notification_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="@android:color/transparent"
    android:minHeight="72dp">

    <!-- Main Content Container -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="16dp">

        <!-- Title Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/notification_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Location Tracking"
                android:textColor="@color/driver_notif_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:maxLines="2"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Description -->
        <TextView
            android:id="@+id/notification_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Background Location Tracking"
            android:textColor="@color/driver_notif_text_secondary"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="8dp" />

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"/>

    </LinearLayout>

    <!-- Status Container -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Connection Status -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/driver_notification_status_bg"
            android:padding="8dp"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/notification_sync_status"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/baseline_wifi_24"
                android:tint="@color/driver_notif_chip_text"
                android:contentDescription="Connection Status" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Online"
                android:textColor="@color/driver_notif_chip_text"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

        <!-- Accuracy Mode -->
        <TextView
            android:id="@+id/accuracy_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="High Accuracy"
            android:textColor="@color/driver_notif_text_secondary"
            android:textSize="10sp"
            android:fontFamily="sans-serif"
            android:background="@drawable/driver_notification_accuracy_bg"
            android:padding="4dp"
            android:gravity="center" />

    </LinearLayout>

</LinearLayout>
