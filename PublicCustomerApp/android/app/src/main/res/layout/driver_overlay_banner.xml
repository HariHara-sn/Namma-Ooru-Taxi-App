<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/driver_overlay_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_margin="8dp"
        android:background="@drawable/driver_overlay_card_bg"
        android:clipToOutline="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:drawablePadding="8dp"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:minWidth="280dp"
        android:maxWidth="420dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="20dp">

        <ImageView
            android:id="@+id/overlay_app_icon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"
            android:contentDescription="@string/app_name"
            android:scaleType="centerInside"
            android:src="@mipmap/ic_launcher_round" />

        <TextView
            android:id="@+id/overlay_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="New Trip Request"
            android:textColor="#222"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/overlay_trip_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="sans-serif"
            android:text="@string/overlay_trip_header"
            android:textColor="#444"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Optional info rows injected by controller -->
        <LinearLayout
            android:id="@+id/overlay_info_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/overlay_bonus_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#2E7D32"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:background="@drawable/overlay_bonus_badge"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:visibility="gone"
                android:text="🎁 Special prize added for this trip" />

            <TextView
                android:id="@+id/overlay_distance_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#444"
                android:textSize="13sp"
                android:fontFamily="sans-serif"
                android:visibility="gone"
                android:text="📏 Distance: -- km" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/overlay_trip_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/overlay_timer_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <ProgressBar
                android:id="@+id/overlay_timer_progress"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:indeterminate="false"
                android:max="1000"
                android:progress="1000"
                android:progressDrawable="@drawable/driver_overlay_progress" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/overlay_reject_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#FF4343"
                android:fontFamily="sans-serif-medium"
                android:text="Reject"
                android:textColor="@android:color/white" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/overlay_accept_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#7d5fff"
                android:fontFamily="sans-serif-medium"
                android:text="Accept"
                android:textColor="@android:color/white" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
