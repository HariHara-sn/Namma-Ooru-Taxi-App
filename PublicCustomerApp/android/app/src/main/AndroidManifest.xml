        <meta-data
            android:name="ne.sdk.VersioningEnabled"
            android:value="false" />
        <meta-data
            android:name="ne.sdk.SDK_BASE"
            android:value="VM" />
        <meta-data
            android:name="com.dieam.reactnativepushnotification.notification_foreground"
            android:value="false" /> <!-- Change the resource name to your App's accent color - or any other color you want -->
        <meta-data
            android:name="com.dieam.reactnativepushnotification.notification_color"
            android:resource="@color/white" />
        <service
            android:name=".tracking.LocationForegroundService"
            android:exported="false"
            android:foregroundServiceType="location" />


        <receiver
            android:name=".tracking.StopTrackingReceiver"
            android:exported="false" />

          <receiver
            android:name="com.virtualmaze.bundle_downloader.receiver.AppUpdateReceiver"
            tools:node="remove" />


            <service
              android:name="com.virtualmaze.prcustomer.driverTracking.DriverLocationService"
              android:enabled="true"
              android:exported="false"
              android:foregroundServiceType="location" />

            <!-- Native FCM Service for background message handling -->
            <service
              android:name="com.virtualmaze.prcustomer.serviceWakeUp.FcmServiceWakeUp"
              android:exported="true"
              android:permission="com.google.android.c2dm.permission.SEND">
              <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
              </intent-filter>
            </service>

        <receiver
            android:name="com.virtualmaze.prcustomer.serviceWakeUp.TripNotificationReceiver"
            android:exported="true"
            android:permission="com.google.android.c2dm.permission.SEND">
            <intent-filter android:priority="999">
                <action android:name="com.google.android.c2dm.intent.RECEIVE" />
                <action android:name="com.virtualmaze.prcustomer.NEW_TRIP_REQUEST" />
            </intent-filter>
        </receiver>

        <service
            android:name="com.virtualmaze.prcustomer.overlay.OverlayHeadlessService"
            android:exported="false"
            android:permission="android.permission.BIND_JOB_SERVICE" />
     
     <!-- Razorpay Deeplink Activity -->
        <activity
    android:name="com.razorpay.DeeplinkActivity"
    tools:node="merge">

    <!-- Remove the Razorpay HTTPS app-link mapping -->
    <intent-filter tools:node="remove">
        <action android:name="android.intent.action.VIEW" />
        <category android:name="android.intent.category.DEFAULT" />
        <category android:name="android.intent.category.BROWSABLE" />

        <data android:scheme="https" android:host="pg-router.dev.razorpay.in" />
    </intent-filter>
</activity>
